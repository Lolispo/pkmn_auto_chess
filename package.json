  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.22.2",
    "immutable": "^3.8.2",
    "immutable-shuffle": "^1.0.3",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "mocha": "^11.1.0",
    "rewire": "^7.0.0"
  },
  "overrides": {
