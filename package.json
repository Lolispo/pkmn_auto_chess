  "description": "Pokemon Auto Chess",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "complete": "eslint ./src && mocha --exit && node src/index.js",
    "pretest": "eslint ./src && mocha --exit",
